<Window x:Class="NL2SQL.GUI.ConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认执行" Height="450" Width="650"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="12"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <StackPanel>
                <TextBlock x:Name="txtTitle" FontSize="16" FontWeight="SemiBold" Foreground="#1976D2"/>
                <TextBlock x:Name="txtDescription" Foreground="#757575" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- 数据预览 -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="10"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="📋 数据预览" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <DataGrid x:Name="dgPreview" AutoGenerateColumns="True" IsReadOnly="True"
                          GridLinesVisibility="All" HeadersVisibility="Column"
                          BorderThickness="0" AlternatingRowBackground="#F9F9F9"
                          FontSize="12" CanUserSortColumns="True"
                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"/>
            </DockPanel>
        </Border>

        <!-- SQL 和按钮 -->
        <Border Grid.Row="4" Background="White" CornerRadius="8" Padding="12"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="📄 将执行的 SQL" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBox x:Name="txtSql" IsReadOnly="True" FontFamily="Consolas" FontSize="12"
                         Background="#FAFAFA" Padding="6" MaxHeight="80"
                         VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                         BorderBrush="#E0E0E0" BorderThickness="1"/>
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="✓ 确认执行" x:Name="btnConfirm" Click="BtnConfirm_Click"
                            Width="100" Height="32" Background="#4CAF50" Foreground="White" BorderThickness="0"/>
                    <Button Content="✗ 取消" Click="BtnCancel_Click"
                            Width="80" Height="32" Background="#9E9E9E" Foreground="White" BorderThickness="0" Margin="8,0,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
