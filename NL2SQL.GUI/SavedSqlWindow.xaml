<Window x:Class="NL2SQL.GUI.SavedSqlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="常用 SQL" Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧：分类列表 -->
        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="8"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="📁 分类" FontWeight="SemiBold" Margin="4,4,4,8"/>
                <ListBox x:Name="lstCategories" SelectionChanged="LstCategories_SelectionChanged"
                         BorderThickness="0" Background="Transparent"/>
            </DockPanel>
        </Border>

        <!-- 右侧：SQL 列表 -->
        <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="8"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="📋 常用 SQL（点击展开/折叠）" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Content="使用选中" Click="BtnUse_Click" Height="26" Padding="10,0"
                            FontSize="12" Background="#4CAF50" Foreground="White" BorderThickness="0"
                            Margin="12,0,0,0"/>
                    <Button Content="删除选中" Click="BtnDelete_Click" Height="26" Padding="10,0"
                            FontSize="12" Background="#F44336" Foreground="White" BorderThickness="0"
                            Margin="6,0,0,0"/>
                    <Button Content="关闭" Click="BtnClose_Click" Height="26" Padding="10,0"
                            FontSize="12" Background="#9E9E9E" Foreground="White" BorderThickness="0"
                            Margin="6,0,0,0"/>
                </StackPanel>
                <ListBox x:Name="lstSavedSql" BorderThickness="0" Background="Transparent"
                         SelectionChanged="LstSavedSql_SelectionChanged"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="0" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                <Expander Padding="8">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Category}" Foreground="#1976D2" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text=" - " Foreground="#9E9E9E"/>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                        </StackPanel>
                                    </Expander.Header>
                                    <Expander.Content>
                                        <Border Background="#F5F5F5" CornerRadius="4" Padding="8" Margin="0,4,0,4">
                                            <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Auto">
                                                <TextBlock Text="{Binding Sql}" FontFamily="Consolas" FontSize="12"
                                                           TextWrapping="Wrap" Foreground="#333333"/>
                                            </ScrollViewer>
                                        </Border>
                                    </Expander.Content>
                                </Expander>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</Window>
