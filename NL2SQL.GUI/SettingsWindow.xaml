<Window x:Class="NL2SQL.GUI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="配置管理" Height="650" Width="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 模型配置 -->
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="12"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="🤖 AI 模型" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Content="+ 新增" Click="BtnAddModel_Click" Height="26" Padding="10,0"
                            FontSize="12" Background="#4CAF50" Foreground="White" BorderThickness="0"
                            Margin="12,0,0,0"/>
                    <Button Content="🗑 删除" Click="BtnDeleteModel_Click" Height="26" Padding="10,0"
                            FontSize="12" Background="#F44336" Foreground="White" BorderThickness="0"
                            Margin="6,0,0,0"/>
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 模型列表 -->
                    <ListBox Grid.Column="0" x:Name="lstModels" SelectionChanged="LstModels_SelectionChanged"
                             BorderThickness="1" BorderBrush="#E0E0E0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" Margin="4"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 模型详情 -->
                    <StackPanel Grid.Column="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="名称：" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtModelName" FontSize="13" Padding="4"
                                     BorderBrush="#E0E0E0" BorderThickness="1"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="API Key：" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtModelApiKey" FontSize="13" Padding="4"
                                     BorderBrush="#E0E0E0" BorderThickness="1"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Base URL：" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtModelBaseUrl" FontSize="13" Padding="4"
                                     BorderBrush="#E0E0E0" BorderThickness="1"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="模型名：" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="6" Grid.Column="1" x:Name="txtModelId" FontSize="13" Padding="4"
                                     BorderBrush="#E0E0E0" BorderThickness="1"/>

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="API 类型：" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal">
                                <ComboBox x:Name="cmbApiType" Height="28" Width="150">
                                    <ComboBoxItem Content="OpenAI 兼容" Tag="OpenAI"/>
                                    <ComboBoxItem Content="Anthropic (Claude)" Tag="Anthropic"/>
                                </ComboBox>
                                <TextBlock Text="DeepSeek/GPT 选 OpenAI" Foreground="#9E9E9E"
                                           FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </DockPanel>
        </Border>

        <!-- 数据库连接配置 -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="12"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="🗄️ 数据库连接" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Content="+ 新增" Click="BtnAddConn_Click" Height="26" Padding="10,0"
                            FontSize="12" Background="#4CAF50" Foreground="White" BorderThickness="0"
                            Margin="12,0,0,0"/>
                    <Button Content="🗑 删除" Click="BtnDeleteConn_Click" Height="26" Padding="10,0"
                            FontSize="12" Background="#F44336" Foreground="White" BorderThickness="0"
                            Margin="6,0,0,0"/>
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 连接列表 -->
                    <ListBox Grid.Column="0" x:Name="lstConnections" SelectionChanged="LstConnections_SelectionChanged"
                             BorderThickness="1" BorderBrush="#E0E0E0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock Text=" - " Foreground="#9E9E9E"/>
                                    <TextBlock Text="{Binding Dialect}" Foreground="#1976D2" FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 连接详情 -->
                    <Grid Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="名称：" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtConnName" FontSize="13" Padding="4"
                                 BorderBrush="#E0E0E0" BorderThickness="1"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="数据库：" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="cmbDialect" Height="28" Width="150"
                                  HorizontalAlignment="Left">
                            <ComboBoxItem Content="MySQL" Tag="MySQL"/>
                            <ComboBoxItem Content="Oracle" Tag="Oracle"/>
                            <ComboBoxItem Content="SqlServer" Tag="SqlServer"/>
                            <ComboBoxItem Content="PostgreSQL" Tag="PostgreSQL"/>
                            <ComboBoxItem Content="SQLite" Tag="SQLite"/>
                        </ComboBox>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="连接串：" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtConnStr" FontSize="12" Padding="4"
                                 BorderBrush="#E0E0E0" BorderThickness="1" TextWrapping="Wrap"
                                 AcceptsReturn="True" Height="50"/>
                    </Grid>
                </Grid>
            </DockPanel>
        </Border>

        <!-- 按钮 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="保存所有" Click="BtnSave_Click"
                    Width="90" Height="32" Background="#4CAF50" Foreground="White" BorderThickness="0" Margin="0,0,8,0"/>
            <Button Content="取消" Click="BtnCancel_Click"
                    Width="80" Height="32" Background="#9E9E9E" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
