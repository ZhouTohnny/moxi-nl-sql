<Window x:Class="NL2SQL.GUI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="数据库连接配置" Height="520" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- API Key -->
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="12"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="DeepSeek API Key" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox x:Name="txtApiKey" FontSize="13" Padding="6"
                         BorderBrush="#E0E0E0" BorderThickness="1"/>
            </StackPanel>
        </Border>

        <!-- 连接列表 -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="12"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="数据库连接" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Content="+ 新增" Click="BtnAdd_Click" Height="26" Padding="10,0"
                            FontSize="12" Background="#4CAF50" Foreground="White" BorderThickness="0"
                            Margin="12,0,0,0"/>
                    <Button Content="🗑 删除" x:Name="btnDelete" Click="BtnDelete_Click" Height="26" Padding="10,0"
                            FontSize="12" Background="#F44336" Foreground="White" BorderThickness="0"
                            Margin="6,0,0,0"/>
                </StackPanel>
                <ListBox x:Name="lstConnections" SelectionChanged="LstConnections_SelectionChanged"
                         BorderThickness="1" BorderBrush="#E0E0E0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text=" - " Foreground="#9E9E9E"/>
                                <TextBlock Text="{Binding Dialect}" Foreground="#1976D2"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- 编辑区域 -->
        <Border Grid.Row="4" Background="White" CornerRadius="8" Padding="12"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <StackPanel x:Name="panelEdit">
                <TextBlock Text="连接详情" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="名称：" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtName" FontSize="13" Padding="4"
                             BorderBrush="#E0E0E0" BorderThickness="1"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="数据库：" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="cmbDialect" Height="28" Width="150"
                              HorizontalAlignment="Left">
                        <ComboBoxItem Content="MySQL" Tag="MySQL"/>
                        <ComboBoxItem Content="Oracle" Tag="Oracle"/>
                        <ComboBoxItem Content="SqlServer" Tag="SqlServer"/>
                        <ComboBoxItem Content="PostgreSQL" Tag="PostgreSQL"/>
                        <ComboBoxItem Content="SQLite" Tag="SQLite"/>
                    </ComboBox>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="连接串：" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtConnStr" FontSize="12" Padding="4"
                             BorderBrush="#E0E0E0" BorderThickness="1" TextWrapping="Wrap"
                             AcceptsReturn="True" Height="50"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 按钮 -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="保存所有" Click="BtnSave_Click"
                    Width="90" Height="32" Background="#4CAF50" Foreground="White" BorderThickness="0" Margin="0,0,8,0"/>
            <Button Content="取消" Click="BtnCancel_Click"
                    Width="80" Height="32" Background="#9E9E9E" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
