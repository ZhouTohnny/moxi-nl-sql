<Window x:Class="NL2SQL.GUI.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SQL 历史记录" Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 历史列表 -->
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="8"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="📜 历史记录（双击复用）" FontWeight="SemiBold" Margin="4,4,4,8"/>
                <ListBox x:Name="lstHistory" BorderThickness="0" Background="Transparent"
                         MouseDoubleClick="LstHistory_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="6" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Database}" Foreground="#1976D2" FontWeight="SemiBold" FontSize="12"/>
                                        <TextBlock Text="{Binding CreatedAt, StringFormat='  yyyy-MM-dd HH:mm'}" Foreground="#9E9E9E" FontSize="11"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding NaturalLanguage}" FontSize="13" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding Sql, Converter={StaticResource TruncateConverter}}" Foreground="#757575"
                                               FontSize="11" FontFamily="Consolas" Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- 按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="🗑 清空历史" Click="BtnClearHistory_Click"
                    Height="32" Padding="12,0" Background="#F44336" Foreground="White" BorderThickness="0"/>
            <Button Content="关闭" Click="BtnClose_Click"
                    Height="32" Padding="12,0" Background="#9E9E9E" Foreground="White" BorderThickness="0" Margin="8,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
