<Window x:Class="NL2SQL.GUI.ResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="查询结果" Height="500" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部信息栏 -->
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="10,8" Margin="0,0,0,8"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📊 查询结果" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtInfo" Foreground="#757575" VerticalAlignment="Center" Margin="16,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="📋 复制全部" Click="BtnCopyAll_Click" Height="28" Padding="10,0"
                            FontSize="12" Background="#FF9800" Foreground="White" BorderThickness="0"/>
                    <Button Content="关闭" Click="BtnClose_Click" Height="28" Padding="10,0"
                            FontSize="12" Background="#9E9E9E" Foreground="White" BorderThickness="0" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 数据表格 -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="8"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <DataGrid x:Name="dgResult" AutoGenerateColumns="True" IsReadOnly="True"
                      GridLinesVisibility="All" HeadersVisibility="Column"
                      BorderThickness="0" AlternatingRowBackground="#F9F9F9"
                      FontSize="12" FontFamily="Microsoft YaHei"
                      CanUserSortColumns="True" CanUserResizeColumns="True"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"/>
        </Border>
    </Grid>
</Window>
